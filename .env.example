# Token da sua aplicação (para proteger a API com chave secreta)
API_TOKEN=sua-chave-secreta

# URL base da API REST do Magento 2 (geralmente termina com /rest)
MAGENTO_API_URL=https://seudominio.com.br/rest

# Token de autenticação gerado no Magento 2 (usado no Authorization Bearer)
MAGENTO_ACCESS_TOKEN=seu-token-magento
