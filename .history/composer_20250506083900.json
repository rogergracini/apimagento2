{
  "name": "vip/apimagento2",
  "description": "API personalizada para integração com Magento 2.4.7",
  "type": "project",
  "require": {
    "php": "^8.1",
    "slim/slim": "^4.10",
    "slim/psr7": "^1.5",
    "vlucas/phpdotenv": "^5.5",
    "guzzlehttp/guzzle": "^7.0",
    "monolog/monolog": "^2.0",
    "php-di/php-di": "^6.4",
    "psr/container": "^1.1"  // ⚠️ versão compatível com php-di
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
